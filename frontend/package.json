{
  "name": "nook",
  "version": "1.0.0",
  "description": "Local AI Chat Application",
  "keywords": [
    "ai",
    "chat"
  ],
  "repository": {
    "type": "git",
    "url": "tbf"
  },
  "license": "GPL-3.0-only",
  "author": "NookWorks",
  "main": "./dist-electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "package": "electron-builder --dir --win"
  },
  "build": {
    "appId": "com.locxl.nook",
    "productName": "Nook",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "icon": "../build/nook.ico"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.1.0",
    "electron-store": "^11.0.2",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "43.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
